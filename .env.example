# Copy file ini menjadi .env dan isi nilainya

# PostgreSQL connection string (dari Railway / Supabase / dsb)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# API Key Dinoiki untuk LLM
DINOIKI_API_KEY=your-dinoiki-api-key-here

# Secret key Flask (generate random string)
SECRET_KEY=your-random-secret-key-here
